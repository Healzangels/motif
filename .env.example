# motif .env (v1.4.0+) — bootstrap secrets only
#
# motif's main configuration lives in /config/motif.yaml after first boot
# and is managed from the web UI at /settings. This .env file is for:
#
#   1. Secrets (Plex token) you don't want stored in motif.yaml
#   2. Settings you want to override from env regardless of what the UI says
#      (12-factor override semantics — env always wins)
#
# Copy this to /mnt/user/appdata/motif/.env (or wherever your compose file
# lives) and edit. Only MOTIF_PLEX_TOKEN is strictly required.

# ============================================================================
# REQUIRED — Plex auth
# ============================================================================
# Find your token at:
#   https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
MOTIF_PLEX_TOKEN=PLACEHOLDER_REPLACE_ME

# ============================================================================
# OPTIONAL — bootstrap defaults
# ============================================================================
# These are written to motif.yaml on first boot if motif.yaml doesn't exist.
# After that, the UI is the source of truth. Setting them in env makes them
# permanent overrides — the UI fields will show "// ENV OVERRIDE" badges.
#
# Uncomment any you want to lock in via env.

# MOTIF_PLEX_URL=http://192.168.1.10:32400
# MOTIF_PLEX_SECTION_EXCLUDE=Home Movies,Music Videos
# MOTIF_PLEX_SECTION_INCLUDE=Movies,4K Movies,TV Shows,Anime

# Optional: TVDB API key — enables orphan-theme resolution during scans for
# folders that have no matching ThemerrDB record and no .nfo sidecar.
# Get one at https://thetvdb.com/api-information (paid v4 subscription).
# MOTIF_TVDB_API_KEY=your_tvdb_v4_api_key_here
# MOTIF_THEMES_DIR=/data/media/themes
# MOTIF_DL_RATE_HOUR=30
# MOTIF_SYNC_CRON=0 13 * * *
# MOTIF_DRY_RUN=true
# MOTIF_LOG_LEVEL=INFO

# ============================================================================
# OPTIONAL — auth bridging
# ============================================================================
# Set 'true' ONLY when motif is behind a forward-auth proxy (e.g. Authentik
# via NPM) that injects X-Authentik-Username. False for direct LAN access.
# MOTIF_TRUST_FORWARD_AUTH=false
